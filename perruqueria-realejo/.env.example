# ==========================================
# VARIABLES DE ENTORNO
# Perruquería Canina Realejo — Demo
# ==========================================

# ------------------------------------------
# Neon PostgreSQL (Base de datos)
# ------------------------------------------
# Obtener estos valores desde: https://console.neon.tech/
# Crear un proyecto nuevo y copiar la Connection String
NEON_DATABASE_URL=
NEON_DIRECT_URL=

# ------------------------------------------
# Resend (Emails transaccionales)
# ------------------------------------------
# Obtener desde: https://resend.com/api-keys
RESEND_API_KEY=
# Email de origen (verificado en Resend)
RESEND_FROM_EMAIL=
# En DEMO: todos los emails se envían a esta dirección
RESEND_TO_EMAIL_DEMO=demo@ejemplo.com

# ------------------------------------------
# Configuración de la App
# ------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_DEMO=true

# ------------------------------------------
# Credenciales Admin (usuario inicial)
# ------------------------------------------
ADMIN_EMAIL=admin@demo.local
ADMIN_PASSWORD=cambia_esto_en_produccion

# ------------------------------------------
# Contacto (placeholders para DEMO)
# ------------------------------------------
NEXT_PUBLIC_PHONE=6XX XXX XXX
NEXT_PUBLIC_EMAIL=contacto@ejemplo.com
NEXT_PUBLIC_ADDRESS=C. Molinos 47, Local, 18009 Granada
NEXT_PUBLIC_WHATSAPP=34600000000

# ------------------------------------------
# Horarios (placeholders para DEMO)
# ------------------------------------------
NEXT_PUBLIC_SCHEDULE=L–V 10:00–17:45 (confirmar)

# ------------------------------------------
# Mapa (Google Maps embed)
# ------------------------------------------
# Coordenadas C. Molinos 47, Granada
NEXT_PUBLIC_MAP_LAT=37.1769
NEXT_PUBLIC_MAP_LNG=-3.5968
NEXT_PUBLIC_MAP_ZOOM=15

# ------------------------------------------
# Vercel (automático en despliegue)
# ------------------------------------------
# Estas variables se configuran automáticamente en Vercel
# No es necesario establecerlas localmente

# ------------------------------------------
# Instrucciones:
# ------------------------------------------
# 1. Copia este archivo a .env.local:
#    cp .env.example .env.local
# 2. Rellena los valores reales en .env.local
# 3. NUNCA commits .env.local al repo
# 4. En Vercel, configura estas variables en Project Settings > Env Variables
