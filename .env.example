# ── Supabase ──────────────────────────────────────────────────────────
# URL y claves de tu proyecto Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Clave service_role (solo servidor; NUNCA exponer en cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (emails transaccionales) ──────────────────────────────────
RESEND_API_KEY=re_...
# Remitente verificado en Resend
EMAIL_FROM="Perruquería Canina Realejo <demo@por2duros.com>"

# ── Modo demo ─────────────────────────────────────────────────────────
# Mientras DEMO_MODE=true, TODOS los emails se desvían a DEMO_EMAIL_TO
DEMO_MODE=true
DEMO_EMAIL_TO=pruebas@por2duros.com

# ── Cron (Vercel) ─────────────────────────────────────────────────────
# Secreto para proteger /api/cron/emails (Vercel lo envía como Bearer)
CRON_SECRET=cambia-esto-por-un-secreto-largo

# ── Sitio ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://perruqueria-realejo-demo.vercel.app
# WhatsApp del negocio (placeholder en demo)
NEXT_PUBLIC_WHATSAPP=34600000000
