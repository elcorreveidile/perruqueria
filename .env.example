# ── Neon (base de datos Postgres) ─────────────────────────────────────
# Cadena de conexión del proyecto (console.neon.tech → Connection string)
DATABASE_URL=postgresql://usuario:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Acceso al panel /admin ────────────────────────────────────────────
ADMIN_EMAIL=demo@por2duros.com
ADMIN_PASSWORD=PerruqueriaDemo2026!
# Secreto para firmar la cookie de sesión (texto largo aleatorio)
AUTH_SECRET=cambia-esto-por-un-secreto-largo

# ── Resend (emails transaccionales) ──────────────────────────────────
RESEND_API_KEY=re_...
# Remitente verificado en Resend
EMAIL_FROM="Perruquería Canina Realejo <demo@por2duros.com>"

# ── Modo demo ─────────────────────────────────────────────────────────
# Mientras DEMO_MODE=true, TODOS los emails se desvían a DEMO_EMAIL_TO
DEMO_MODE=true
DEMO_EMAIL_TO=pruebas@por2duros.com

# ── Cron (Vercel) ─────────────────────────────────────────────────────
# Secreto para proteger /api/cron/emails (Vercel lo envía como Bearer)
CRON_SECRET=cambia-esto-por-otro-secreto-largo

# ── Sitio ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://perruqueria.vercel.app
# WhatsApp del negocio (placeholder en demo)
NEXT_PUBLIC_WHATSAPP=34600000000
